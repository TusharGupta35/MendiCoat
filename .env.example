DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mendi_coat?schema=public
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
EMAIL_SERVER=smtp://username:password@smtp.example.com:587
EMAIL_FROM=hello@example.com

# Voice chat TURN relay (needed for reliable P2P audio across strict NATs).
# Leave unset to use a free public fallback. Multiple URLs may be comma-separated.
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
